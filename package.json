{
  "name": "show-opencode-sessions",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "bin": "build/server.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "pkg:build": "npm run build && esbuild server.ts --bundle --platform=node --target=node18 --outfile=build/server.cjs --format=cjs --external:sql.js && pkg . --targets node18-macos-x64,node18-macos-arm64,node18-linux-x64,node18-win-x64 --out-path bin && node scripts/pack-binaries.cjs"
  },
  "pkg": {
    "assets": [
      "dist/**/*",
      "node_modules/sql.js/dist/sql-wasm.wasm"
    ]
  },
  "dependencies": {
    "lucide-react": "^0.542.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sql.js": "^1.13.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.12",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react-swc": "^4.0.1",
    "esbuild": "^0.27.4",
    "open": "^11.0.0",
    "pkg": "^5.8.1",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.9.2",
    "vite": "^7.1.3"
  }
}